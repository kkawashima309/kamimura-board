<Window x:Class="PdfStudio.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PdfStudio.Wpf.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        Title="PdfStudio"
        Height="800" Width="1280"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseTabCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding PrintCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding ShowSearchPanelCommand}" />
        <KeyBinding Key="G" Modifiers="Ctrl" Command="{Binding GoToPageCommand}" />
        <!-- ズーム: + は OemPlus、- は OemMinus 、0 は D0 -->
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Add" Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ZoomActualCommand}" />
        <KeyBinding Key="NumPad0" Modifiers="Ctrl" Command="{Binding ZoomActualCommand}" />
        <!-- ページ移動 -->
        <KeyBinding Key="PageUp" Command="{Binding PrevPageCommand}" />
        <KeyBinding Key="PageDown" Command="{Binding NextPageCommand}" />
        <KeyBinding Key="Home" Modifiers="Ctrl" Command="{Binding FirstPageCommand}" />
        <KeyBinding Key="End" Modifiers="Ctrl" Command="{Binding LastPageCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeletePageCommand}" />
        <!-- 検索結果ナビゲーション -->
        <KeyBinding Key="F3" Command="{Binding NextSearchResultCommand}" />
        <KeyBinding Key="F3" Modifiers="Shift" Command="{Binding PrevSearchResultCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: メニュー -->
            <RowDefinition Height="Auto" />  <!-- 1: ツールバー -->
            <RowDefinition Height="Auto" />  <!-- 2: 検索パネル (新規) -->
            <RowDefinition Height="Auto" />  <!-- 3: タブ -->
            <RowDefinition Height="*" />     <!-- 4: メインエリア -->
            <RowDefinition Height="Auto" />  <!-- 5: ステータスバー -->
        </Grid.RowDefinitions>

        <!-- メニュー -->
        <Menu Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="開く...(_O)" Command="{Binding OpenCommand}"
                          InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="上書き保存(_S)" Command="{Binding SaveCommand}"
                          InputGestureText="Ctrl+S" />
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsCommand}"
                          InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="印刷(_P)..." Command="{Binding PrintCommand}"
                          InputGestureText="Ctrl+P" />
                <Separator />
                <MenuItem Header="最近使ったファイル(_R)"
                          ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Menu}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="最近使ったファイルをクリア(_C)"
                          Command="{Binding ClearRecentFilesCommand}" />
                <Separator />
                <MenuItem Header="タブを閉じる(_W)" Command="{Binding CloseTabCommand}"
                          InputGestureText="Ctrl+W" />
                <MenuItem Header="終了(_X)" Click="ExitMenu_Click" />
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す(_U)" Command="{Binding UndoCommand}"
                          InputGestureText="Ctrl+Z" />
                <MenuItem Header="やり直し(_R)" Command="{Binding RedoCommand}"
                          InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="検索(_F)..." Command="{Binding ShowSearchPanelCommand}"
                          InputGestureText="Ctrl+F" />
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="拡大(_I)" Command="{Binding ZoomInCommand}"
                          InputGestureText="Ctrl+ホイール↑" />
                <MenuItem Header="縮小(_O)" Command="{Binding ZoomOutCommand}"
                          InputGestureText="Ctrl+ホイール↓" />
                <MenuItem Header="実寸(100%)(_A)" Command="{Binding ZoomActualCommand}"
                          InputGestureText="Ctrl+0" />
                <MenuItem Header="ページ全体に合わせる(_F)" Command="{Binding ZoomFitPageCommand}" />
                <MenuItem Header="幅に合わせる(_W)" Command="{Binding ZoomFitWidthCommand}" />
                <Separator />
                <MenuItem Header="先頭ページへ(_T)" Command="{Binding FirstPageCommand}"
                          InputGestureText="Home" />
                <MenuItem Header="前のページ(_P)" Command="{Binding PrevPageCommand}"
                          InputGestureText="PageUp" />
                <MenuItem Header="次のページ(_N)" Command="{Binding NextPageCommand}"
                          InputGestureText="PageDown" />
                <MenuItem Header="最終ページへ(_E)" Command="{Binding LastPageCommand}"
                          InputGestureText="End" />
                <MenuItem Header="指定ページへ移動(_G)..." Command="{Binding GoToPageCommand}"
                          InputGestureText="Ctrl+G" />
            </MenuItem>
            <MenuItem Header="ページ(_P)">
                <MenuItem Header="削除(_D)" Command="{Binding DeletePageCommand}"
                          InputGestureText="Delete" />
                <MenuItem Header="左に90度回転(_L)" Command="{Binding RotatePageLeftCommand}" />
                <MenuItem Header="右に90度回転(_R)" Command="{Binding RotatePageRightCommand}" />
                <Separator />
                <MenuItem Header="別PDFからページを挿入(_I)..." Command="{Binding InsertPagesFromFileCommand}" />
                <MenuItem Header="ページを抽出(_E)..." Command="{Binding ExtractPagesCommand}" />
                <MenuItem Header="白紙ページを挿入(_B)..." Command="{Binding InsertBlankPageCommand}" />
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <MenuItem Header="PDFを結合(_M)..." Command="{Binding MergePdfsCommand}" />
                <MenuItem Header="PDFを分割(_S)..." Command="{Binding SplitPdfCommand}" />
                <Separator />
                <MenuItem Header="パスワードを設定(_P)..." Command="{Binding SetPasswordCommand}" />
                <Separator />
                <MenuItem Header="プロパティを表示(_V)..." Command="{Binding ShowPropertiesCommand}" />
                <MenuItem Header="プロパティを編集(_E)..." Command="{Binding EditPropertiesCommand}" />
                <Separator />
                <MenuItem Header="ウォーターマーク追加(_W)..." Command="{Binding AddWatermarkCommand}" />
                <MenuItem Header="ページ番号追加(_N)..." Command="{Binding AddPageNumbersCommand}" />
                <MenuItem Header="ヘッダー/フッター追加(_H)..." Command="{Binding AddHeaderFooterCommand}" />
                <Separator />
                <MenuItem Header="画像としてエクスポート(_X)..." Command="{Binding ExportPageAsImageCommand}" />
                <Separator />
                <MenuItem Header="複数PDFに一括ウォーターマーク(_B)..." Command="{Binding BatchWatermarkCommand}" />
            </MenuItem>
            <MenuItem Header="注釈(_A)">
                <MenuItem Header="電子スタンプ(_S)..." Command="{Binding AddStampCommand}" />
                <MenuItem Header="付箋(コメント)(_N)..." Command="{Binding AddStickyNoteCommand}" />
            </MenuItem>
            <MenuItem Header="OCR(_O)">
                <MenuItem Header="文字認識を実行(_R)..." Command="{Binding PerformOcrCommand}" />
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- ツールバー -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="📂 開く" Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenCommand}" ToolTip="ファイルを開く (Ctrl+O)" />
                <Button Content="💾 保存" Style="{StaticResource ToolbarButton}"
                        Command="{Binding SaveCommand}" ToolTip="保存 (Ctrl+S)" />
                <Button Content="🖨 印刷" Style="{StaticResource ToolbarButton}"
                        Command="{Binding PrintCommand}" ToolTip="印刷 (Ctrl+P)" />
                <Separator Margin="6,4" />
                <Button Content="↶" Style="{StaticResource ToolbarButton}"
                        Command="{Binding UndoCommand}" ToolTip="元に戻す (Ctrl+Z)"
                        FontSize="16" />
                <Button Content="↷" Style="{StaticResource ToolbarButton}"
                        Command="{Binding RedoCommand}" ToolTip="やり直し (Ctrl+Y)"
                        FontSize="16" />
                <Separator Margin="6,4" />
                <Button Content="🔍 検索" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ShowSearchPanelCommand}" ToolTip="PDF内テキスト検索 (Ctrl+F)" />
                <Separator Margin="6,4" />
                <Button Content="🔄 左回転" Style="{StaticResource ToolbarButton}"
                        Command="{Binding RotatePageLeftCommand}" ToolTip="左に90度回転" />
                <Button Content="🔄 右回転" Style="{StaticResource ToolbarButton}"
                        Command="{Binding RotatePageRightCommand}" ToolTip="右に90度回転" />
                <Button Content="🗑 削除" Style="{StaticResource ToolbarButton}"
                        Command="{Binding DeletePageCommand}" ToolTip="ページ削除 (Delete)" />
                <Separator Margin="6,4" />
                <Button Content="📑 結合" Style="{StaticResource ToolbarButton}"
                        Command="{Binding MergePdfsCommand}" ToolTip="複数PDFを結合" />
                <Button Content="✂ 分割" Style="{StaticResource ToolbarButton}"
                        Command="{Binding SplitPdfCommand}" ToolTip="PDFを分割" />
                <Separator Margin="6,4" />
                <Button Content="➖" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ZoomOutCommand}" ToolTip="縮小 (Ctrl+-)" />
                <Button Content="100%" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ZoomActualCommand}" ToolTip="実寸 (Ctrl+0)" />
                <Button Content="➕" Style="{StaticResource ToolbarButton}"
                        Command="{Binding ZoomInCommand}" ToolTip="拡大 (Ctrl++)" />
                <Separator Margin="6,4" />
                <Button Content="🔒 パスワード" Style="{StaticResource ToolbarButton}"
                        Command="{Binding SetPasswordCommand}" ToolTip="パスワードを設定" />
            </StackPanel>
        </Border>

        <!-- 検索パネル (IsSearchPanelVisible=true のときだけ表示) -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="{Binding IsSearchPanelVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍 検索:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Padding="6,2"
                         ToolTip="検索文字列を入力してEnterまたは検索ボタンをクリック">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteSearchCommand}" />
                        <KeyBinding Key="Escape" Command="{Binding ShowSearchPanelCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="2" Content="検索"
                        Command="{Binding ExecuteSearchCommand}"
                        Padding="12,2" Margin="8,0,0,0" />
                <Button Grid.Column="3" Content="◀"
                        Command="{Binding PrevSearchResultCommand}"
                        ToolTip="前へ (Shift+F3)"
                        Padding="8,2" Margin="8,0,0,0" />
                <Button Grid.Column="4" Content="▶"
                        Command="{Binding NextSearchResultCommand}"
                        ToolTip="次へ (F3)"
                        Padding="8,2" Margin="4,0,0,0" />
                <CheckBox Grid.Column="5" Content="大小区別" VerticalAlignment="Center"
                          IsChecked="{Binding SearchCaseSensitive}" Margin="12,0,0,0" />
                <Button Grid.Column="6" Content="✕"
                        Command="{Binding ShowSearchPanelCommand}"
                        ToolTip="閉じる (Esc)"
                        Padding="6,2" Margin="8,0,0,0" />
            </Grid>
        </Border>

        <!-- タブ -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="{Binding OpenDocuments.Count,
                             Converter={StaticResource CountToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding OpenDocuments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,4,0"
                                Padding="10,4"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Cursor="Hand"
                                MouseLeftButtonDown="TabBorder_MouseLeftButtonDown">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"
                                            Value="{StaticResource SurfaceBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource SelectedBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- メインエリア -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="100" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- サムネイルパネル -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock Text="ページ"
                               Style="{StaticResource PanelHeader}"
                               DockPanel.Dock="Top" />
                    <ListBox x:Name="ThumbnailList"
                             ItemsSource="{Binding ActiveDocument.Pages}"
                             SelectedItem="{Binding ActiveDocument.CurrentPage,
                                            Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ThumbnailList_SelectionChanged"
                             AllowDrop="True"
                             PreviewMouseMove="ThumbnailList_PreviewMouseMove"
                             Drop="ThumbnailList_Drop">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4"
                                        Padding="6"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <Border BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                Background="White"
                                                MinHeight="100">
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform"
                                                   MaxHeight="200" />
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="3"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" />

            <!-- PDFビューア -->
            <Grid Grid.Column="2" Background="{StaticResource BackgroundBrush}">
                <!-- スタート画面 -->
                <Grid Visibility="{Binding ActiveDocument,
                                  Converter={StaticResource NullToVisibleConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="600">
                        <TextBlock Text="PdfStudio"
                                   FontSize="36"
                                   FontWeight="Light"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="PDFファイルをドラッグ＆ドロップするか、ボタンから操作を開始してください"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource SubTextBrush}"
                                   Margin="0,12,0,32" />
                        <UniformGrid Columns="2" Rows="2">
                            <Button Content="📂 PDFを開く"
                                    Command="{Binding OpenCommand}"
                                    Margin="8" Padding="20,16"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="14"
                                    Cursor="Hand" />
                            <Button Content="📑 PDFを結合"
                                    Command="{Binding MergePdfsCommand}"
                                    Margin="8" Padding="20,16"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    FontSize="14"
                                    Cursor="Hand" />
                            <Button Content="✂ PDFを分割"
                                    Command="{Binding SplitPdfCommand}"
                                    Margin="8" Padding="20,16"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    FontSize="14"
                                    Cursor="Hand" />
                            <Button Content="🔒 パスワード保護"
                                    Command="{Binding SetPasswordCommand}"
                                    Margin="8" Padding="20,16"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    FontSize="14"
                                    Cursor="Hand" />
                        </UniformGrid>

                        <!-- 最近使ったファイル -->
                        <TextBlock Text="最近使ったファイル"
                                   FontWeight="SemiBold"
                                   Margin="0,32,0,8"
                                   Visibility="{Binding RecentFiles.Count,
                                                Converter={StaticResource CountToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding RecentFiles}"
                                      Visibility="{Binding RecentFiles.Count,
                                                   Converter={StaticResource CountToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Margin="0,2"
                                            Padding="8,6"
                                            HorizontalContentAlignment="Left"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Foreground="{StaticResource AccentBrush}"
                                            Command="{Binding DataContext.OpenRecentCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- PDF表示 -->
                <ScrollViewer x:Name="PdfScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BackgroundBrush}"
                              PreviewMouseWheel="PdfScrollViewer_PreviewMouseWheel"
                              Visibility="{Binding ActiveDocument,
                                           Converter={StaticResource NotNullToVisibleConverter}}">
                    <Border Padding="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                        <Border Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Effect="{x:Null}">
                            <Grid>
                                <Image x:Name="PdfPageImage"
                                       Source="{Binding ActiveDocument.CurrentPageImage}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top">
                                    <Image.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ActiveDocument.ZoomLevel}"
                                                        ScaleY="{Binding ActiveDocument.ZoomLevel}" />
                                    </Image.LayoutTransform>
                                </Image>

                                <!-- 検索ヒットのハイライト矩形オーバーレイ(黄色=全ヒット、オレンジ=選択中) -->
                                <ItemsControl ItemsSource="{Binding ActiveDocument.PageHighlights}"
                                              Width="{Binding ActualWidth, ElementName=PdfPageImage}"
                                              Height="{Binding ActualHeight, ElementName=PdfPageImage}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Top"
                                              IsHitTestVisible="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource FractionToPixelConverter}">
                                                        <Binding Path="Left" />
                                                        <Binding Path="ActualWidth"
                                                                 RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Top">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource FractionToPixelConverter}">
                                                        <Binding Path="Top" />
                                                        <Binding Path="ActualHeight"
                                                                 RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Rectangle StrokeThickness="2">
                                                <Rectangle.Width>
                                                    <MultiBinding Converter="{StaticResource FractionToPixelConverter}">
                                                        <Binding Path="Width" />
                                                        <Binding Path="ActualWidth"
                                                                 RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    </MultiBinding>
                                                </Rectangle.Width>
                                                <Rectangle.Height>
                                                    <MultiBinding Converter="{StaticResource FractionToPixelConverter}">
                                                        <Binding Path="Height" />
                                                        <Binding Path="ActualHeight"
                                                                 RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    </MultiBinding>
                                                </Rectangle.Height>
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Stroke" Value="#FFD700" />
                                                        <Setter Property="Fill" Value="#55FFD700" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Stroke" Value="#FF8C00" />
                                                                <Setter Property="Fill" Value="#55FF8C00" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Border>
                </ScrollViewer>

                <!-- ローディング表示 -->
                <Border Background="#80000000"
                        Visibility="{Binding IsBusy,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200" Height="6" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="5"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusText}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource StatusText}">
                        <Run Text="ページ " />
                        <Run Text="{Binding ActiveDocument.CurrentPage.DisplayNumber, Mode=OneWay, FallbackValue=-}" />
                        <Run Text=" / " />
                        <Run Text="{Binding ActiveDocument.Pages.Count, Mode=OneWay, FallbackValue=-}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
