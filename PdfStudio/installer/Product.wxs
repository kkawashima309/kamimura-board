<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    PdfStudio MSI インストーラー定義 (WiX v4)
    - ターゲット: Program Files (x64)
    - 管理者権限必須 (perMachine)
    - スタートメニュー & デスクトップにショートカット
    - .pdf 右クリック「PdfStudio で開く」を追加
  -->
  <Package Name="PdfStudio"
           Manufacturer="Kamimura Denki Kogyo Co., Ltd."
           Version="0.5.7.0"
           UpgradeCode="9C8A7B3E-4F2D-4A1C-8E5F-2B6D9A3C7E8F"
           Scope="perMachine"
           Compressed="yes"
           Codepage="932"
           Language="1041"
           InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="より新しいバージョンの [ProductName] が既にインストールされています。" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- アイコン -->
    <Icon Id="PdfStudioIcon.exe" SourceFile="..\assets\PdfStudio.ico" />
    <Property Id="ARPPRODUCTICON" Value="PdfStudioIcon.exe" />
    <!-- ARPNOMODIFY は WixUI_InstallDir が自動設定するため、ここでは指定しない -->
    <Property Id="ARPCOMMENTS" Value="Windows 向け PDF 編集ツール" />

    <!-- ディレクトリ構造 -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PdfStudio" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="PdfStudio" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- スタートメニュー ショートカット -->
    <Component Id="ApplicationShortcuts"
               Directory="ApplicationProgramsFolder"
               Guid="A1B2C3D4-E5F6-4A7B-8C9D-1E2F3A4B5C6D">
      <Shortcut Id="ApplicationStartMenuShortcut"
                Name="PdfStudio"
                Description="Windows 向け PDF 編集ツール"
                Target="[INSTALLFOLDER]PdfStudio.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="PdfStudioIcon.exe" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Kamimura Denki Kogyo\PdfStudio"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- デスクトップ ショートカット -->
    <Component Id="DesktopShortcut"
               Directory="DesktopFolder"
               Guid="B2C3D4E5-F6A7-4B8C-9D1E-2F3A4B5C6D7E">
      <Shortcut Id="ApplicationDesktopShortcut"
                Name="PdfStudio"
                Description="Windows 向け PDF 編集ツール"
                Target="[INSTALLFOLDER]PdfStudio.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="PdfStudioIcon.exe" />
      <RegistryValue Root="HKCU"
                     Key="Software\Kamimura Denki Kogyo\PdfStudio"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- .pdf の右クリックメニュー「PdfStudio で開く」 -->
    <Component Id="FileAssociation"
               Directory="INSTALLFOLDER"
               Guid="C3D4E5F6-A7B8-4C9D-1E2F-3A4B5C6D7E8F">
      <RegistryKey Root="HKLM" Key="Software\Classes\SystemFileAssociations\.pdf\shell\OpenWithPdfStudio">
        <RegistryValue Type="string" Value="PdfStudio で開く" />
        <RegistryValue Name="Icon" Type="string" Value="[INSTALLFOLDER]PdfStudio.exe,0" />
      </RegistryKey>
      <RegistryKey Root="HKLM" Key="Software\Classes\SystemFileAssociations\.pdf\shell\OpenWithPdfStudio\command">
        <RegistryValue Type="string" Value="&quot;[INSTALLFOLDER]PdfStudio.exe&quot; &quot;%1&quot;" />
      </RegistryKey>
    </Component>

    <!-- Feature ツリー -->
    <Feature Id="MainFeature"
             Title="PdfStudio 本体"
             Description="PdfStudio アプリケーション本体と必要なファイル"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="ApplicationComponents" />
      <ComponentRef Id="ApplicationShortcuts" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="FileAssociation" />
    </Feature>

    <!-- UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!-- ライセンス表示 (RTF) -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
